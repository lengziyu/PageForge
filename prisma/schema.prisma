generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model SitePage {
  id        String     @id @default(cuid())
  title     String
  slug      String     @unique
  status    PageStatus @default(PUBLISHED)
  content   Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model SiteNewsArticle {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  category    String
  summary     String
  coverImage  String
  contentHtml String     @db.Text
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SiteNewsCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
