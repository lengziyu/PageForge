generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model SitePage {
  id        String   @id @default(cuid())
  title     String
  slug      String     @unique
  status    String   @default("PUBLISHED")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteNewsArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String     @unique
  category    String
  summary     String
  coverImage  String
  contentHtml String
  status      String   @default("DRAFT")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteNewsCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteProduct {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  category       String
  summary        String
  coverImage     String
  galleryJson    String   @default("[]")
  highlightsJson String   @default("[]")
  specsJson      String   @default("[]")
  contentHtml    String
  status         String   @default("DRAFT")
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SiteProductCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
